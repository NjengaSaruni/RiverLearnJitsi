# Jitsi Meet Self-Hosted - .gitignore

# Environment files
.env
.env.local
.env.production
.env.staging
jitsi.env
*.env

# Docker volumes and data
prosody/
jicofo/
jvb/
web/
volumes/
data/

# SSL certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx
letsencrypt/
ssl/
certs/

# Logs
*.log
logs/
debug.log
error.log
access.log

# Backup files
backups/
*.backup
*.bak
*.tar.gz
*.zip

# Temporary files
tmp/
temp/
.tmp/
.temp/

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Node.js (if any)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python (if any)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
env.bak/
venv.bak/

# Docker
.dockerignore
docker-compose.override.yml
docker-compose.*.yml
!docker-compose.yml

# Secrets and sensitive data
secrets/
*.secret
*.private
config/secrets/
auth/

# Generated files
generated/
build/
dist/

# Monitoring and metrics
metrics/
monitoring/
grafana/
prometheus/

# Database files
*.db
*.sqlite
*.sqlite3

# Cache
.cache/
cache/

# Runtime files
*.pid
*.sock
*.lock

# Configuration overrides
config.local.js
config.production.js
config.staging.js

# Deployment specific
deployment/
terraform/
ansible/
k8s/
kubernetes/

# Local development
local/
dev/
development/

# Test files
test/
tests/
coverage/
.nyc_output/

# Documentation build
docs/_build/
site/

# Jitsi specific
jitsi-meet/
jitsi-videobridge/
jicofo/
prosody/

# Generated secrets (will be created by setup script)
JICOFO_SECRET=*
FOCUS_PASSWORD=*
JVB_PASSWORD=*

# Server specific
server-ip.txt
external-ip.txt
instance-id.txt

# Cloud specific
.gcloud/
gcloud-config/
service-account.json
credentials.json

# Monitoring logs
/var/log/jitsi/
monitor.log
health-check.log
deployment.log
